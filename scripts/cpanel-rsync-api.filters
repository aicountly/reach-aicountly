# cPanel api/ rsync filters (use: rsync --filter='merge scripts/cpanel-rsync-api.filters')
#
# PRODUCTION RULE: api/.env on the server is never uploaded, overwritten, or deleted by deploy.
#
# - .env     do not copy from CI (secrets live only on the server)
# P .env     never delete the server's .env when using --delete
#
# .env.example is NOT listed — it is deployed from git on every release.

P .env
- .env

# Preserve server runtime data across --delete deploys
P writable/.reach_seed_complete
P writable/cache/
P writable/logs/
P writable/session/
P writable/uploads/
