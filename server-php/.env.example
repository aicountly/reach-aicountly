# AICOUNTLY Reach Marketing Portal API (CodeIgniter 4.6)
# Copy to .env locally; never commit a real .env.

CI_ENVIRONMENT=production
app.baseURL=https://reach.aicountly.org/api/
app.indexPage=

# --- PostgreSQL (Reach marketing DB — never target other portal DBs) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=aicountly_reach
DB_USER=
DB_PASS=

# --- Independent superadmin auth (Reach only; not linked to my.aicountly.com) ---
# Generate: php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
JWT_SECRET=
JWT_TTL_MINUTES=720

# --- CORS — comma-separated origins allowed to call this API ---
ALLOWED_ORIGINS=https://reach.aicountly.org,http://localhost:5173

# --- Seed superadmin (InitialReachSeeder; quote values that contain spaces) ---
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_NAME="Reach Superadmin"
SUPER_ADMIN_PASSWORD=

# --- Reach Marketing Bot ---
# DB row reach_bot_settings.mode is authoritative; this env value is used
# only as a fallback when the settings row is missing.
REACH_BOT_MODE=confirm
REACH_BOT_OPENAI_KEY=
REACH_BOT_ANTHROPIC_KEY=

# --- Console controller SSO (Top Controller identity provider) ---
CONSOLE_API_URL=https://console.aicountly.org/api
CONTROLLER_APP_CODE=reach

# --- Console fan-out (Flow pattern: POST /audit with typed events) ---
CONSOLE_API_BASE_URL=https://console.aicountly.org/api
CONSOLE_API_TOKEN=

# --- Inbound from Console (portal/bot/* endpoints) ---
# Console must send this value in the `X-Console-Token` header.
CONSOLE_INBOUND_TOKEN=

# --- Engage lead push (real endpoint on engage.aicountly.org) ---
# The lead endpoint expects header `X-Portal-Token: <ENGAGE_INBOUND_TOKEN>`.
ENGAGE_API_BASE_URL=https://engage.aicountly.org/api/v1
ENGAGE_INBOUND_TOKEN=

# --- Playwright worker (worker.apis.aicountly.com) ---
# The client degrades gracefully if the endpoints or token are missing.
WORKER_BASE_URL=https://worker.apis.aicountly.com
WORKER_API_TOKEN=

# --- AICOUNTLY.com blog publisher (placeholder) ---
# If either value is empty, approved blogs stay pending_publishing.
AICOUNTLY_SITE_API_BASE_URL=
AICOUNTLY_SITE_API_TOKEN=

# --- Social channel provider tokens (empty = manual posting queue) ---
LINKEDIN_API_TOKEN=
TWITTER_API_TOKEN=
FACEBOOK_API_TOKEN=
INSTAGRAM_API_TOKEN=
YOUTUBE_API_TOKEN=
WHATSAPP_CHANNEL_API_TOKEN=

# --- GA4 Traffic Analytics (ported from Flow — configure on server api/.env only) ---
# Marketing site (aicountly.com)
GA4_PROPERTY_ID_MARKETING=
GOOGLE_SERVICE_ACCOUNT_JSON_MARKETING=
# Reach portal (reach.aicountly.org) — falls back to GA4_PROPERTY_ID_PORTAL if unset
GA4_PROPERTY_ID_REACH=
GOOGLE_SERVICE_ACCOUNT_JSON_REACH=
GA4_PROPERTY_ID_PORTAL=
GOOGLE_SERVICE_ACCOUNT_JSON_PORTAL=
# Shared my.aicountly.com SaaS hub property (pagePath filters per product when no dedicated property)
GA4_PROPERTY_ID_SAAS=
GOOGLE_SERVICE_ACCOUNT_JSON_SAAS=
AICOUNTLY_SITE_URL=https://www.aicountly.com
AIC_GLOBAL_URL=https://my.aicountly.com
REACH_APP_URL=https://reach.aicountly.org
# Per-product GA4 (optional — copy from Flow .env.ga4.example, e.g. GA4_PROPERTY_ID_SAAS_SMART_BOOKS)
# GA4_PROPERTY_ID_SAAS_SMART_BOOKS=
# GOOGLE_SERVICE_ACCOUNT_JSON_SAAS_SMART_BOOKS=

# --- Legacy provider placeholders (Reach UI uses GA4 streams above) ---
GSC_SITE_URL=
META_ACCESS_TOKEN=
LINKEDIN_ANALYTICS_TOKEN=
TWITTER_ANALYTICS_TOKEN=
YOUTUBE_ANALYTICS_TOKEN=
EMAIL_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_API_KEY=

# --- Public lead-capture token (used by embeddable landing/form widgets) ---
# Rotate periodically. Empty disables the public /v1/public/leads/capture route.
PUBLIC_LEAD_CAPTURE_TOKEN=
