{
    "name": "aicountly/reach-api",
    "description": "AICOUNTLY Reach Marketing Portal API (CodeIgniter 4.6 + PostgreSQL)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.6",
        "ezyang/htmlpurifier": "^4.17",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support/",
            "Tests\\Unit\\": "tests/Unit/",
            "Tests\\Feature\\": "tests/Feature/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@composer dump-autoload"
        ],
        "migrate": "php spark migrate",
        "seed": "php spark db:seed InitialReachSeeder",
        "test": "phpunit --no-coverage",
        "test:coverage": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
